{
  "name": "vane-site",
  "private": true,
  "version": "0.0.0",
  "description": "Marketing and documentation site for Vane — a DuckDB-compatible engine for multimodal data pipelines on Ray.",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:en": "docusaurus start",
    "dev:zh-CN": "docusaurus start --locale zh-CN",
    "build": "docusaurus build",
    "docs:lint": "node scripts/docs-lint.mjs",
    "docs:llms": "node scripts/docs-llms.mjs",
    "docs:llms:check": "node scripts/docs-llms.mjs --check",
    "docs:manifest": "node scripts/docs-manifest.mjs",
    "docs:manifest:check": "node scripts/docs-manifest.mjs --check",
    "enterprise:content:check": "node scripts/enterprise-use-case-check.mjs",
    "home:content:check": "node scripts/home-content-check.mjs",
    "training:content:check": "node scripts/training-use-case-check.mjs",
    "solutions:content:check": "node scripts/solutions-content-check.mjs",
    "write-translations": "docusaurus write-translations --locale zh-CN",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "docusaurus serve"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/plugin-content-docs": "^3.10.1",
    "@docusaurus/theme-classic": "^3.10.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.1",
    "@docusaurus/tsconfig": "^3.10.1",
    "@eslint/js": "^10.0.1",
    "@mdx-js/react": "^3.1.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
